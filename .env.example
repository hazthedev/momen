# ============================================
# MOMEN ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local for local development
# DO NOT commit .env.local to git!

# ============================================
# CRITICAL - Application will not start without these
# ============================================

# Database Connection
DATABASE_URL="postgresql://user:password@host:5432/momen?sslmode=require"

# Session & Authentication
SESSION_SECRET="generate-a-random-32-character-string-here"
JWT_ACCESS_SECRET="generate-another-random-32-character-string-here"
JWT_REFRESH_SECRET="generate-a-third-random-32-character-string-here"

# Application
APP_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================
# REQUIRED - Core features depend on these
# ============================================

# Redis (Upstash or self-hosted)
REDIS_URL="redis://localhost:6379"

# Cloudflare R2 (Image Storage)
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="momen-uploads"
R2_PUBLIC_URL="https://pub-xxxxxxxxx.r2.dev"

# ============================================
# OPTIONAL - Feature flags and integrations
# ============================================

# Feature Flags
FEATURE_PHOTO_UPLOAD="true"
FEATURE_ATTENDANCE="true"
FEATURE_LUCKY_DRAW="true"
FEATURE_PHOTO_CHALLENGE="true"

# Error Tracking (Sentry)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="1.0"

# Analytics (Vercel - auto-set in production)
# VERCEL_ANALYTICS_ID=""

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Database Connection Pool (development)
DATABASE_POOL_MIN="0"
DATABASE_POOL_MAX="2"

# Enable debug logging
DEBUG="momen:*"

# ============================================
# PRODUCTION OVERRAYS
# ============================================

# When NODE_ENV=production, these override development defaults:
# - DATABASE_POOL_MIN="2"
# - DATABASE_POOL_MAX="20"
# - DEBUG=""
# - Cookies get Secure flag
# - HTTP-only cookies enabled
# - SameSite=Strict for cookies

# ============================================
# GENERATE SECRETS
# ============================================
# Use these commands to generate secure random strings:
#
# Node.js:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# OpenSSL:
# openssl rand -base64 32
#
# Python:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
